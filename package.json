{
	"name": "@forestnpm/n8n-nodes-forest",
	"version": "1.0.12",
	"description": "n8n community node for Forest",
	"keywords": [
		"n8n-community-node-package"
	],
	"license": "MIT",
	"homepage": "https://github.com/ForestAdmin/n8n-nodes-forest",
	"author": {
		"name": "Pierre Merlet",
		"email": "pierre.merlet@forestadmin.com"
	},
	"repository": {
		"type": "git",
		"url": "https://github.com/ForestAdmin/n8n-nodes-forest.git"
	},
	"engines": {
		"node": ">=18.10",
		"pnpm": ">=9.1"
	},
	"main": "index.js",
	"scripts": {
		"build": "rm -rf dist && tsc --noEmit && node esbuild.config.mjs && gulp build:icons",
		"dev": "tsc --watch",
		"format": "prettier nodes credentials --write",
		"lint": "n8n-node lint",
		"lintfix": "n8n-node lint --fix",
		"prepublishOnly": "pnpm build && pnpm lint"
	},
	"files": [
		"dist"
	],
	"n8n": {
		"n8nNodesApiVersion": 1,
		"strict": false,
		"credentials": [
			"dist/credentials/ForestMcpApi.credentials.js",
			"dist/credentials/ForestMcpOAuth2Api.credentials.js"
		],
		"nodes": [
			"dist/nodes/Forest/Forest.node.js"
		]
	},
	"devDependencies": {
		"@n8n/node-cli": "^0.28.0",
		"@types/node": "^22.0.0",
		"esbuild": "^0.27.3",
		"eslint": "^9.32.0",
		"gulp": "^4.0.2",
		"prettier": "^3.6.2",
		"typescript": "^5.9.2"
	},
	"publishConfig": {
		"access": "public"
	},
	"peerDependencies": {
		"n8n-workflow": "*"
	},
	"packageManager": "pnpm@9.15.9"
}
